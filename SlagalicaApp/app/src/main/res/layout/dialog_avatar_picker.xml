<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="horizontal"
    android:padding="16dp">

    <ImageView
        android:id="@+id/iv_pick_1"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_margin="6dp"
        android:background="@drawable/bg_avatar_okvir"
        android:clickable="true"
        android:contentDescription="@string/btn_promeni_avatar"
        android:focusable="true"
        android:padding="2dp"
        android:src="@drawable/avatar_1" />

    <ImageView
        android:id="@+id/iv_pick_2"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_margin="6dp"
        android:background="@drawable/bg_avatar_okvir"
        android:clickable="true"
        android:contentDescription="@string/btn_promeni_avatar"
        android:focusable="true"
        android:padding="2dp"
        android:src="@drawable/avatar_2" />

    <ImageView
        android:id="@+id/iv_pick_3"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_margin="6dp"
        android:background="@drawable/bg_avatar_okvir"
        android:clickable="true"
        android:contentDescription="@string/btn_promeni_avatar"
        android:focusable="true"
        android:padding="2dp"
        android:src="@drawable/avatar_3" />

    <ImageView
        android:id="@+id/iv_pick_4"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_margin="6dp"
        android:background="@drawable/bg_avatar_okvir"
        android:clickable="true"
        android:contentDescription="@string/btn_promeni_avatar"
        android:focusable="true"
        android:padding="2dp"
        android:src="@drawable/avatar_4" />

</LinearLayout>