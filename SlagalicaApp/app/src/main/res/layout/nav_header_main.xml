<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="@dimen/nav_header_visina"
    android:background="@color/primary"
    android:fitsSystemWindows="true"
    android:gravity="bottom"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingBottom="16dp"
    android:paddingTop="24dp">

    <ImageView
        android:id="@+id/ivAvatar"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@android:drawable/ic_menu_myplaces"
        android:background="@drawable/bg_avatar_okvir"
        android:padding="4dp"
        android:scaleType="centerCrop"/>

    <TextView
        android:id="@+id/tvKorisnickoImeNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Korisnik"
        android:textAppearance="@style/TextAppearance.AppCompat.Body1"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:textSize="16sp"/>

    <TextView
        android:id="@+id/tvEmailNav"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="korisnik@email.com"
        android:textColor="@color/white"
        android:alpha="0.8"
        android:textSize="13sp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvTokeniNav"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🪙 5 tokena"
            android:textColor="@color/accent"
            android:textSize="13sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="  |  "
            android:textColor="@color/white"
            android:alpha="0.5"/>

        <TextView
            android:id="@+id/tvZvjezdiceNav"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⭐ 0 zvjezdica"
            android:textColor="@color/accent"
            android:textSize="13sp"/>

    </LinearLayout>

</LinearLayout>
