<?xml version="1.0" encoding="utf-8"?>
<!-- Igra Korak po korak: 7 koraka, odbrojava se sa max 20 bodova -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/margin_medium">


        <!-- Scoreboard: moji bodovi vs protivnik -->
        <include
            android:id="@+id/scoreboardKorak"
            layout="@layout/item_scoreboard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

                <!-- Header: korak i timer -->
        <LinearLayout
            android:id="@+id/llHeaderKorak"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/scoreboardKorak">

            <!-- Aktuelni korak i max bodovi -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvBrojKoraka"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Korak 1 / 7"
                    android:textColor="@color/primary"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvBodoviKorak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Možete osvoji: 20 bodova"
                    android:textColor="@color/boja_bodova_pozitivno"
                    android:textSize="13sp"/>

            </LinearLayout>

            <!-- Timer - odbrojava po 10s za svaki korak -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="@color/primary">

                <TextView
                    android:id="@+id/tvTimerKorak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:text="10"
                    android:textColor="@color/white"
                    android:textSize="@dimen/timer_vel"
                    android:textStyle="bold"
                    android:fontFamily="monospace"/>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- Progress bar koraka (1-7) -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressKoraci"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:progress="14"
            app:trackCornerRadius="4dp"
            app:indicatorColor="@color/accent"
            app:trackColor="@color/skocko_prazno"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/llHeaderKorak"/>

        <!-- Naslov traženog pojma - skriven dok se ne otkrije -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTrazeniPojam"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/primary"
            app:cardElevation="6dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/progressKoraci">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎯 TRAŽENI POJAM"
                    android:textColor="@color/accent"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tvTrazeniPojam"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="_ _ _ _ _ _ _"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:gravity="center"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Kartica tekućeg koraka - pojam koji ukazuje na rješenje -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAktuelniKorak"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/surface"
            app:cardElevation="4dp"
            app:strokeColor="@color/accent"
            app:strokeWidth="2dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardTrazeniPojam">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NAPUTAK"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tvAktuelniKorakTekst"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Čeka se naputak..."
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:gravity="center"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Lista otkrivenih koraka -->
        <TextView
            android:id="@+id/tvLabelPrethodni"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Prethodni naputci:"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardAktuelniKorak"/>

        <LinearLayout
            android:id="@+id/llPrethodnihKoraka"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvLabelPrethodni"/>

        <!-- Unos odgovora -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilOdgovorKorak"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="@string/hint_upisite_odgovor"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/llPrethodnihKoraka">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etOdgovorKorak"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:imeOptions="actionDone"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Dugmad -->
        <LinearLayout
            android:id="@+id/llDugmadKorak"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tilOdgovorKorak">

            <!-- Pogodi traženi pojam -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPogudiKorak"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pogodi!"
                android:textAllCaps="false"
                app:cornerRadius="12dp"/>

            <!-- Sljedeći korak (otvori novi naputak) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSledecKorak"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/btn_sledeci_korak"
                android:textAllCaps="false"
                app:cornerRadius="12dp"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
