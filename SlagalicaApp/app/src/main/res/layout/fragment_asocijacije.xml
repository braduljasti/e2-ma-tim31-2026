<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true"
    tools:context=".ui.games.AsocijacijeFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/margin_medium">

        <include
            android:id="@+id/scoreboardAsoc"
            layout="@layout/item_scoreboard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/llHeaderAsoc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/scoreboardAsoc">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvBrojRundeAsoc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Runda 1 / 2"
                    android:textColor="@color/primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvMaxBodoviAsoc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/asoc_max_bodova"
                    android:textColor="@color/boja_bodova_pozitivno"
                    android:textSize="13sp" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTimerAsoc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/timer_normalno"
                app:cardCornerRadius="12dp">

                <TextView
                    android:id="@+id/tvTimerAsoc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:padding="10dp"
                    android:text="120"
                    android:textColor="@color/white"
                    android:textSize="28sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressRundeAsoc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:progress="50"
            app:indicatorColor="@color/accent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/llHeaderAsoc"
            app:trackColor="@color/skocko_prazno"
            app:trackCornerRadius="4dp" />

        <LinearLayout
            android:id="@+id/llIgraliste"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/progressRundeAsoc">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <include android:id="@+id/cellA1" layout="@layout/item_asocijacije_celija" />
                    <include android:id="@+id/cellA2" layout="@layout/item_asocijacije_celija" />
                    <include android:id="@+id/cellA3" layout="@layout/item_asocijacije_celija" />
                    <include android:id="@+id/cellA4" layout="@layout/item_asocijacije_celija" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <include android:id="@+id/cellB1" layout="@layout/item_asocijacije_celija" />
                    <include android:id="@+id/cellB2" layout="@layout/item_asocijacije_celija" />
                    <include android:id="@+id/cellB3" layout="@layout/item_asocijacije_celija" />
                    <include android:id="@+id/cellB4" layout="@layout/item_asocijacije_celija" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <include
                    android:id="@+id/resenjeA"
                    layout="@layout/item_asocijacije_celija"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <include
                    android:id="@+id/resenjeB"
                    layout="@layout/item_asocijacije_celija"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:orientation="horizontal">

                <include
                    android:id="@+id/resenjeFinalno"
                    layout="@layout/item_asocijacije_celija"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.7" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <include
                    android:id="@+id/resenjeC"
                    layout="@layout/item_asocijacije_celija"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <include
                    android:id="@+id/resenjeD"
                    layout="@layout/item_asocijacije_celija"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <include android:id="@+id/cellC1" layout="@layout/item_asocijacije_celija" />
                    <include android:id="@+id/cellC2" layout="@layout/item_asocijacije_celija" />
                    <include android:id="@+id/cellC3" layout="@layout/item_asocijacije_celija" />
                    <include android:id="@+id/cellC4" layout="@layout/item_asocijacije_celija" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <include android:id="@+id/cellD1" layout="@layout/item_asocijacije_celija" />
                    <include android:id="@+id/cellD2" layout="@layout/item_asocijacije_celija" />
                    <include android:id="@+id/cellD3" layout="@layout/item_asocijacije_celija" />
                    <include android:id="@+id/cellD4" layout="@layout/item_asocijacije_celija" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDaljeAsoc"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="16dp"
            android:text="@string/btn_dalje"
            android:textAllCaps="false"
            android:textColor="@color/text_secondary"
            app:cornerRadius="12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/llIgraliste" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
