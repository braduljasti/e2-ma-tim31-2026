<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="4dp"
    android:background="@android:color/transparent">

    <TextView
        android:id="@+id/tvPolje1"
        android:layout_width="@dimen/skocko_red_celija_vel"
        android:layout_height="@dimen/skocko_red_celija_vel"
        android:layout_margin="3dp"
        android:background="@drawable/bg_skocko_celija_prazna"
        android:gravity="center"
        android:textSize="20sp"/>

    <TextView
        android:id="@+id/tvPolje2"
        android:layout_width="@dimen/skocko_red_celija_vel"
        android:layout_height="@dimen/skocko_red_celija_vel"
        android:layout_margin="3dp"
        android:background="@drawable/bg_skocko_celija_prazna"
        android:gravity="center"
        android:textSize="20sp"/>

    <TextView
        android:id="@+id/tvPolje3"
        android:layout_width="@dimen/skocko_red_celija_vel"
        android:layout_height="@dimen/skocko_red_celija_vel"
        android:layout_margin="3dp"
        android:background="@drawable/bg_skocko_celija_prazna"
        android:gravity="center"
        android:textSize="20sp"/>

    <TextView
        android:id="@+id/tvPolje4"
        android:layout_width="@dimen/skocko_red_celija_vel"
        android:layout_height="@dimen/skocko_red_celija_vel"
        android:layout_margin="3dp"
        android:background="@drawable/bg_skocko_celija_prazna"
        android:gravity="center"
        android:textSize="20sp"/>

    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_weight="1"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <View
                android:id="@+id/indikator1"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_margin="2dp"
                android:background="@drawable/bg_skocko_indikator_prazan"/>

            <View
                android:id="@+id/indikator2"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_margin="2dp"
                android:background="@drawable/bg_skocko_indikator_prazan"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <View
                android:id="@+id/indikator3"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_margin="2dp"
                android:background="@drawable/bg_skocko_indikator_prazan"/>

            <View
                android:id="@+id/indikator4"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_margin="2dp"
                android:background="@drawable/bg_skocko_indikator_prazan"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
