rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid;
      match /{document=**} {
        allow read, write: if signedIn() && request.auth.uid == uid;
      }
    }

    match /usernames/{username} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /matchmaking/{ticketId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn();
    }

    match /kzzQuestions/{id} {
      allow read, write: if signedIn();
    }
    match /spojniceRunde/{id} {
      allow read, write: if signedIn();
    }
    match /asocijacijeRunde/{id} {
      allow read, write: if signedIn();
    }
    match /korakPojmovi/{id} {
      allow read, write: if signedIn();
    }

    match /matches/{matchId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn() &&
        (request.auth.uid == resource.data.player1Id ||
         request.auth.uid == resource.data.player2Id);
    }

    // Obostrano prijateljstvo: samo učesnik para smije da čita/kreira/briše.
    match /friendships/{parId} {
      allow read: if signedIn() && request.auth.uid in resource.data.users;
      allow create: if signedIn() && request.auth.uid in request.resource.data.users;
      allow delete: if signedIn() && request.auth.uid in resource.data.users;
    }

    // Istorija plasmana regiona po ciklusu (spec 5.d/5.e) - čitaju svi prijavljeni,
    // upisuje prvi klijent koji uđe u novi ciklus (arhivira prethodni).
    match /regionStandings/{cycleId} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    // Čet po regionima (spec 8) - svi prijavljeni čitaju, svako piše samo poruke sa svojim uid-om.
    match /chats/{region}/poruke/{msgId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.senderUid == request.auth.uid;
    }

    // Pozivi na prijateljsku partiju (spec 7.c-e): vide ih i mijenjaju samo
    // pošiljalac i primalac; kreirati može samo pošiljalac u svoje ime.
    match /matchInvites/{inviteId} {
      allow read: if signedIn() &&
        (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid);
      allow create: if signedIn() && request.auth.uid == request.resource.data.fromUid;
      allow update: if signedIn() &&
        (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid);
    }
  }
}
